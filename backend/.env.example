# Server
PORT=8080

# API Key – used by the Flutter app to authenticate requests
API_KEY=ChangeMe_SomethingSecret

# Data directory – inside the container this is where the SQLite DB lives.
# Map a Docker volume to this path so data survives container restarts.
DATA_DIR=/data

# Serial port of the P1 digital meter (e.g. /dev/ttyUSB0 on a Raspberry Pi)
P1_SERIAL_PORT=/dev/ttyUSB0
P1_BAUD_RATE=115200

# Snapshot storage interval in milliseconds (60000 = 1 min)
# Quarter-hour peaks are always calculated on exact :00/:15/:30/:45 boundaries.
STORAGE_INTERVAL_MS=60000

# Firebase – path to the service-account JSON (mounted via volume)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT=/data/firebase-service-account.json
